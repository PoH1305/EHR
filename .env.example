# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SMART on FHIR — Epic
EPIC_CLIENT_ID=your_epic_client_id
EPIC_AUTH_ENDPOINT=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize
EPIC_TOKEN_ENDPOINT=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# SMART on FHIR — Cerner
CERNER_CLIENT_ID=your_cerner_client_id
CERNER_AUTH_ENDPOINT=https://authorization.cerner.com/tenants/ec2458f2-1e24-41c8-b71b-0e701af7583d/protocols/oauth2/profiles/smart-v1/personas/patient/authorize
CERNER_TOKEN_ENDPOINT=https://authorization.cerner.com/tenants/ec2458f2-1e24-41c8-b71b-0e701af7583d/protocols/oauth2/profiles/smart-v1/personas/patient/token

# Database (Vercel KV or Upstash Redis)
KV_REST_API_URL=your_kv_url
KV_REST_API_TOKEN=your_kv_token

# Audit DB (separate from main DB — tamper-evident log)
AUDIT_DB_URL=your_audit_db_url
AUDIT_DB_TOKEN=your_audit_db_token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EHI Platform

# Cookie encryption key (32 bytes, hex)
COOKIE_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
