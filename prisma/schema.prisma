// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id                    String        @id
  name                  String
  healthId              String        @unique
  birthDate             String?
  gender                String?
  bloodGroup            String?
  city                  String?
  isMinimizationActive  Boolean       @default(false)
  lastSyncStatus        String?
  syncHash              String?
  vitals                Vital[]
  conditions            Condition[]
  medications           Medication[]
  notes                 ClinicalNote[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Vital {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type         String
  value        String
  unit         String
  timestamp    DateTime @default(now())

  @@index([patientId])
}

model Condition {
  id             String   @id
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  code           String
  display         String
  clinicalStatus String
  onsetDateTime  String?
  createdAt      DateTime @default(now())

  @@index([patientId])
}

model Medication {
  id                  String   @id
  patientId           String
  patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicationReference String
  status              String
  intent              String
  note                String?
  createdAt           DateTime @default(now())

  @@index([patientId])
}

model ClinicalNote {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId  String
  content   String   @db.Text
  timestamp DateTime @default(now())

  @@index([patientId])
}

model AuditEvent {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  type      String
  userId    String
  action    String
  outcome   String
  metadata  Json?
}

model AccessRequest {
  id        String   @id @default(cuid())
  doctorId  String
  patientId String
  status    String   @default("pending")
  purpose   String   @default("Routine")
  timestamp DateTime @default(now())

  @@index([patientId])
}
